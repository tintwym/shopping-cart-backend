# Neon PostgreSQL (copy connection string from Neon dashboard → Connect)
# Used locally with docker compose --env-file .env or on Render as DATABASE_URL
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require

# Alternative explicit JDBC settings (local docker-compose postgres uses application-docker profile instead)
# SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/shoppingcart
# SPRING_DATASOURCE_USERNAME=shoppingcart
# SPRING_DATASOURCE_PASSWORD=shoppingcart

JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars
STRIPE_API_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
APP_FRONTEND_BASE_URL=http://localhost:8081
