# Neon PostgreSQL — copy from Neon dashboard → Connect
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require

JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars
STRIPE_API_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
APP_FRONTEND_BASE_URL=http://localhost:8081

# Cloudinary — product images
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
# CLOUDINARY_FOLDER=shopping-cart/products

# Optional — first admin account (only created if username does not exist)
# ADMIN_SEED_USERNAME=admin
# ADMIN_SEED_PASSWORD=change-me-strong-password

